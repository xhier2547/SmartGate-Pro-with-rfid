# LINE Messaging API
LINE_TOKEN=YOUR_LINE_CHANNEL_ACCESS_TOKEN
LINE_CHANNEL_SECRET=YOUR_LINE_CHANNEL_SECRET

# ค่าตั้งต้น
DEFAULT_LATE_TIME=08:30
PORT=3000
